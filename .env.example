# GrowwPulse Environment Variables

# Gmail & Google Workspace credentials (if running MCP server with env variables)
GOOGLE_CLIENT_ID=your-oauth-client-id
GOOGLE_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REFRESH_TOKEN=your-oauth-refresh-token

# Target email to send the weekly pulse note to
TARGET_EMAIL=your-recipient-email@gmail.com

# LLM API keys (if using external providers directly)
OPENAI_API_KEY=your-openai-api-key
GEMINI_API_KEY=your-gemini-api-key
