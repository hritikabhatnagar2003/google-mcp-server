{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/landing", "destination": "/landing.html" }
  ]
}
